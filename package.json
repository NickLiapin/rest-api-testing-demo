{
  "name": "rest-api-testing-demo",
  "version": "1.0.0",
  "description": "REST API test automation with Playwright (API mode) against a bundled mock service - CRUD, auth, status codes and JSON-schema validation, runs hermetically in CI.",
  "scripts": {
