    "playwright",
    "test-automation",
    "qa-automation",
    "json-schema",
    "ci"
  ],
  "author": "Nick Liapin",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.6.2"
  }
}
